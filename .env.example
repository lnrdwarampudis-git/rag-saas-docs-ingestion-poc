COMPOSE_PROJECT_NAME=rag-saas-docs-ingestion-poc
APP_NAME=rag-saas-docs-ingestion-poc
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/rag
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
QDRANT_URL=http://localhost:6333
KEYCLOAK_ISSUER=http://localhost:8080/realms/rag
KEYCLOAK_AUDIENCE=rag-api
CHUNK_TARGET_TOKENS=750
CHUNK_OVERLAP_TOKENS=120
UPLOAD_DIR=/tmp/rag-uploads
ENABLE_DB_PERSISTENCE=false
HOST_DOWNLOADS_DIR=./data/host-downloads
HOST_MOUNT_SOURCE_PREFIX=
RETRIEVAL_MIN_SCORE=0.12
RETRIEVAL_MIN_KEYWORD_OVERLAP=0.20
LLM_PROVIDER=local
LOCAL_LLM_RUNTIME=extractive
PUBLIC_LLM_ENABLED=false
