[Unit]
Description=RAG SaaS ingestion worker
After=network-online.target rag-backend.service
Wants=network-online.target

[Service]
Type=simple
User=rag
Group=rag
WorkingDirectory=/opt/rag-saas-docs-ingestion-poc
EnvironmentFile=/etc/rag-saas/rag.env
ExecStart=/opt/rag-saas-docs-ingestion-poc/.venv/bin/python -m app.worker
Restart=always
RestartSec=5
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
