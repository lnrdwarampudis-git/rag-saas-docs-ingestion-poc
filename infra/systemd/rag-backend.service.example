[Unit]
Description=RAG SaaS backend API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=rag
Group=rag
WorkingDirectory=/opt/rag-saas-docs-ingestion-poc
EnvironmentFile=/etc/rag-saas/rag.env
ExecStart=/opt/rag-saas-docs-ingestion-poc/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
