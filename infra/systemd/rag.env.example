APP_ENV=production
ENABLE_DB_PERSISTENCE=true
DATABASE_URL=postgresql+psycopg://rag:change-me@postgres.internal:5432/rag
REDIS_URL=redis://redis.internal:6379/0
MINIO_ENDPOINT=http://minio.internal:9000
MINIO_PUBLIC_ENDPOINT=https://minio.example.com
MINIO_ACCESS_KEY=rag
MINIO_SECRET_KEY=change-me
QDRANT_URL=http://qdrant.internal:6333
VECTOR_INDEX_BACKEND=qdrant
LLM_PROVIDER=local
LOCAL_LLM_RUNTIME=extractive
LOCAL_LLM_MODEL_NAME=extractive
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_RUNTIME=hashing
LOCAL_EMBEDDING_MODEL_NAME=hashing-384
PUBLIC_LLM_ENABLED=false
KEYCLOAK_ISSUER_URL=https://auth.example.com/realms/rag-saas
KEYCLOAK_AUDIENCE=rag-saas-docs-api
JWT_SECRET=change-me
PROCESSING_QUEUE_NAME=rag:processing-jobs
OCR_PROCESSING_QUEUE_NAME=rag:processing-jobs:ocr
WORKER_QUEUE_NAMES=rag:processing-jobs,rag:processing-jobs:ocr
WORKER_MAX_JOBS_PER_RUN=0
QUERY_EVENTS_RETENTION_DAYS=30
MODEL_LATENCY_EVENTS_RETENTION_DAYS=30
PROCESSING_JOB_EVENTS_RETENTION_DAYS=30
EVALUATION_RUNS_RETENTION_DAYS=90
