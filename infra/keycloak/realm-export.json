{
  "realm": "rag",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Tenant administrator" },
      { "name": "finance", "description": "Finance team member" },
      { "name": "engineering", "description": "Engineering team member" },
      { "name": "legal", "description": "Legal team member" },
      { "name": "support", "description": "Support team member" }
    ]
  },
  "clients": [
    {
      "clientId": "rag-api",
      "name": "RAG API (resource server)",
      "protocol": "openid-connect",
      "bearerOnly": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    },
    {
      "clientId": "rag-frontend",
      "name": "RAG SaaS Console (SPA)",
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "audience-rag-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "rag-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "tenant-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "id": "10000000-0000-4000-8000-000000000001",
      "username": "admin-demo",
      "email": "admin-demo@example.test",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Alex",
      "lastName": "Admin",
      "attributes": { "tenant_id": ["00000000-0000-4000-8000-000000000001"] },
      "credentials": [{ "type": "password", "value": "Passw0rd!", "temporary": false }],
      "realmRoles": ["admin"]
    },
    {
