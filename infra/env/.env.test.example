COMPOSE_PROJECT_NAME=rag-saas-docs-ingestion-poc-test
APP_NAME=rag-saas-docs-ingestion-poc
ENVIRONMENT=test

# Test defaults favor isolated local checks and deterministic model behavior.
DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/rag_test
REDIS_URL=redis://localhost:6379/1
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
QDRANT_URL=http://localhost:6333
KEYCLOAK_ISSUER=http://localhost:8080/realms/rag
KEYCLOAK_AUDIENCE=rag-api

ENABLE_DB_PERSISTENCE=false
VECTOR_INDEX_BACKEND=memory
RETRIEVAL_MIN_SCORE=0.12
RETRIEVAL_MIN_KEYWORD_OVERLAP=0.20
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_RUNTIME=hashing
LOCAL_EMBEDDING_MODEL_NAME=hashing-384
EMBEDDING_DIMENSIONS=384
LLM_PROVIDER=local
LOCAL_LLM_RUNTIME=extractive
LOCAL_LLM_MODEL_NAME=extractive
LOCAL_MODEL_PROFILE=local-default
LOCAL_MODEL_GPU_PROFILE=none
PUBLIC_LLM_ENABLED=false

UPLOAD_SESSION_STORAGE_BACKEND=filesystem
MAX_UPLOAD_BYTES=536870912
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.txt,.md,.csv,.tsv,.docx,.xlsx,.pptx,.png,.jpg,.jpeg,.tiff,.bmp
OCR_LANGUAGE=eng
OCR_PDF_DPI=200
OCR_MAX_PDF_PAGES=20
