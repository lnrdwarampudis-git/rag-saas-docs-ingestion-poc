COMPOSE_PROJECT_NAME=rag-saas-docs-ingestion-poc-pvs
APP_NAME=rag-saas-docs-ingestion-poc
ENVIRONMENT=pvs

# PVS is the pre-production validation/staging profile.
# Replace placeholder hosts and secrets before use.
DATABASE_URL=postgresql+psycopg://rag:${POSTGRES_PASSWORD}@postgres:5432/rag
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=https://minio-pvs.example.com
QDRANT_URL=http://qdrant:6333
KEYCLOAK_ISSUER=https://keycloak-pvs.example.com/realms/rag
KEYCLOAK_INTERNAL_ISSUER=http://keycloak:8080/realms/rag
KEYCLOAK_AUDIENCE=rag-api
KEYCLOAK_CLIENT_ID=rag-frontend

ENABLE_DB_PERSISTENCE=true
VECTOR_INDEX_BACKEND=qdrant
QDRANT_COLLECTION_NAME=rag_chunks
PGVECTOR_DIMENSIONS=1024
VECTOR_BACKFILL_BATCH_SIZE=100

# PVS still defaults to local/open-source models.
LOCAL_MODEL_PROFILE=local-default
LOCAL_MODEL_GPU_PROFILE=none
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_RUNTIME=hashing
LOCAL_EMBEDDING_MODEL_NAME=hashing-384
EMBEDDING_DIMENSIONS=384
LLM_PROVIDER=local
LOCAL_LLM_RUNTIME=extractive
LOCAL_LLM_MODEL_NAME=extractive
PUBLIC_LLM_ENABLED=false
PUBLIC_LLM_BASE_URL=https://api.openai.com
PUBLIC_LLM_API_KEY=
PUBLIC_LLM_MODEL_NAME=
PUBLIC_EMBEDDING_MODEL_NAME=

UPLOAD_SESSION_STORAGE_BACKEND=minio
UPLOAD_SESSION_BUCKET=rag-upload-sessions
MAX_UPLOAD_BYTES=536870912
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.txt,.md,.csv,.tsv,.docx,.xlsx,.pptx,.png,.jpg,.jpeg,.tiff,.bmp
OCR_LANGUAGE=eng
OCR_PDF_DPI=200
OCR_MAX_PDF_PAGES=20
