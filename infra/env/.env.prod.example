APP_NAME=rag-saas-docs-ingestion-poc
ENVIRONMENT=production

# Production profile. Replace placeholders and move secrets to your platform's
# secret manager before deployment.
DATABASE_URL=postgresql+psycopg://rag:${POSTGRES_PASSWORD}@postgres:5432/rag
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=https://minio.example.com
QDRANT_URL=http://qdrant:6333
KEYCLOAK_ISSUER=https://keycloak.example.com/realms/rag
KEYCLOAK_INTERNAL_ISSUER=http://keycloak:8080/realms/rag
KEYCLOAK_AUDIENCE=rag-api
KEYCLOAK_CLIENT_ID=rag-frontend

POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=change-me
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

ENABLE_DB_PERSISTENCE=true
VECTOR_INDEX_BACKEND=qdrant
QDRANT_COLLECTION_NAME=rag_chunks
PGVECTOR_DIMENSIONS=1024
VECTOR_BACKFILL_BATCH_SIZE=100
QUERY_EVENTS_RETENTION_DAYS=30
MODEL_LATENCY_EVENTS_RETENTION_DAYS=30
PROCESSING_JOB_EVENTS_RETENTION_DAYS=30
EVALUATION_RUNS_RETENTION_DAYS=90

# Keep production local/open-source by default for now. Switch to public
# OpenAI-compatible providers only after approval, rate limits, and cost controls.
LOCAL_MODEL_PROFILE=local-default
LOCAL_MODEL_GPU_PROFILE=none
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_RUNTIME=hashing
LOCAL_EMBEDDING_MODEL_NAME=hashing-384
EMBEDDING_DIMENSIONS=384
LLM_PROVIDER=local
LOCAL_LLM_RUNTIME=extractive
LOCAL_LLM_MODEL_NAME=extractive
PUBLIC_LLM_ENABLED=false
PUBLIC_LLM_BASE_URL=https://api.openai.com
PUBLIC_LLM_API_KEY=
PUBLIC_LLM_MODEL_NAME=
PUBLIC_EMBEDDING_MODEL_NAME=

UPLOAD_SESSION_STORAGE_BACKEND=minio
UPLOAD_SESSION_BUCKET=rag-upload-sessions
UPLOAD_SESSION_PART_BYTES=8388608
UPLOAD_SESSION_MAX_PARTS=10000
UPLOAD_SESSION_CLEANUP_MAX_AGE_HOURS=24
UPLOAD_SESSION_LIFECYCLE_EXPIRATION_DAYS=7
MAX_UPLOAD_BYTES=536870912
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.txt,.md,.csv,.tsv,.docx,.xlsx,.pptx,.png,.jpg,.jpeg,.tiff,.bmp
OCR_LANGUAGE=eng
OCR_PDF_DPI=200
OCR_MAX_PDF_PAGES=20
