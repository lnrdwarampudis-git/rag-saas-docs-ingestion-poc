{
  "family": "rag-saas-ops-retention",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/rag-saas-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/rag-saas-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "ops-retention",
      "image": "<account-id>.dkr.ecr.<region>.amazonaws.com/rag-saas-backend:<tag>",
      "essential": true,
      "command": ["python", "-m", "app.rag.cleanup_ops_history"],
      "environment": [
        { "name": "APP_ENV", "value": "production" },
        { "name": "ENABLE_DB_PERSISTENCE", "value": "true" },
        { "name": "QUERY_EVENTS_RETENTION_DAYS", "value": "30" },
        { "name": "MODEL_LATENCY_EVENTS_RETENTION_DAYS", "value": "30" },
        { "name": "PROCESSING_JOB_EVENTS_RETENTION_DAYS", "value": "30" },
        { "name": "EVALUATION_RUNS_RETENTION_DAYS", "value": "90" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:rag-saas/database-url" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/rag-saas",
          "awslogs-region": "<region>",
          "awslogs-stream-prefix": "ops-retention"
        }
      }
    }
  ]
}
